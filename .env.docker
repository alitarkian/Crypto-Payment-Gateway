APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8080

# Service hostnames = docker-compose service names
DATABASE_URL=postgres://erpos:erpos@host.docker.internal:5432/gateway_db
REDIS_URL=redis://host.docker.internal:6379
RABBITMQ_URL=amqp://erpos:erpos@host.docker.internal:5672/%2F

